        <contributor type="main_dev">
            <name>Julien VILLEMEJANE</name>
            <organization>LEnsE / IOGS</organization>
            <mail>julien.villemejane@institutoptique.fr</mail>
        </contributor>
        <contributor type="sciexp">
            <name>Sébastien de ROSSI</name>
            <organization>LCF / IOGS</organization>
        </contributor>
    </contributors>
	<module>
		<name>baslerlite</name>
		<location>lensepy_app.modules.camera</location>
	</module>
	<module>
		<name>fyzo_analysis</name>
		<location>lensepy_app.modules.optics.fizeau</location>
	</module>
    <variable name="image"/>
    <variable name="bits_depth"/>
    <variable name="camera"/>
    <variable name="mask"/>
    <camera>
        <name>Basler</name>
        <colormode>Mono12:12,Mono10:10,Mono8:8</colormode>
        <exposuretime>200000</exposuretime>
        <maxwidth>1920</maxwidth>
        <maxheight>1200</maxheight>
        <offset>8</offset>
        <init_file>./config/camera_small.ini</init_file>
    </camera>
